# ====================================================
# .gitignore — Kosta Project
# File ini memberitahu Git file apa yang TIDAK perlu
# di-upload ke GitHub
# ====================================================

# -------- File Konfigurasi Sensitif --------
# File berikut berisi kredensial DB & API key,
# JANGAN pernah di-upload ke GitHub!
config/koneksi.php
config/midtrans.php
config/fonnte.php
.env

# -------- File Upload oleh User --------
# Foto kos yang diupload pemilik saat runtime
assets/images/kos/*
!assets/images/kos/.gitkeep

# File upload lainnya
assets/uploads/*
!assets/uploads/.gitkeep

# -------- Cache & Log --------
*.log
*.cache

# -------- File IDE / Editor --------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# -------- OS Generated Files --------
.DS_Store
Thumbs.db
desktop.ini

# -------- Composer (jika ada) --------
/vendor/

# -------- Node Modules (jika ada) --------
node_modules/
